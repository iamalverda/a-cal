# A-Cal Environment Configuration
# Copy to .env and fill in your credentials.
# The app auto-loads .env on startup (python-dotenv).

# --- Database ---
# SQLite is the default (zero config). To use PostgreSQL instead:
# 1. Run: pip install a-cal[postgres]
# 2. Set DATABASE_URL and start the postgres profile:
#    docker compose --profile postgres up --build
# DATABASE_URL=postgresql://acal:acal-dev@localhost:5432/acal

# --- OAuth Client Credentials (for real calendar/email sync) ---
# Google Calendar + Gmail (one client covers both)
A_CAL_GOOGLE_CLIENT_ID=
A_CAL_GOOGLE_CLIENT_SECRET=

# Outlook / Microsoft Graph
A_CAL_MS_CLIENT_ID=
A_CAL_MS_CLIENT_SECRET=

# --- LLM Provider API Keys (for cloud model routing) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# AZURE_OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# TOGETHER_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# MISTRAL_API_KEY=

# --- Local LLM (no API key needed) ---
OLLAMA_BASE_URL=http://localhost:11434
# LM_STUDIO_BASE_URL=http://localhost:1234

# --- CORS ---
A_CAL_CORS_ORIGINS=http://localhost:3456,http://localhost:3000

# --- Session Security (REQUIRED for production) ---
# The session cookie signing secret. The built-in dev secret is insecure and
# MUST be replaced before exposing the server to real users.
# Generate one with: python -c "import secrets;print(secrets.token_urlsafe(48))"
A_CAL_SESSION_SECRET=

# --- Plugin Runtime (optional, default OFF) ---
# Plugins run arbitrary Python code in-process. Only enable for self-hosted,
# single-operator deployments where you trust all plugin code.
# A_CAL_ENABLE_PLUGINS=1

# --- Backend + Frontend URLs (for OAuth redirect URIs + cookie Secure flag) ---
# A_CAL_BASE_URL=https://your-backend.example.com
# A_CAL_FRONTEND_URL=https://your-frontend.example.com

# --- Demo Login (optional, default OFF) ---
# A_CAL_ENABLE_DEMO=1

# --- Database Migrations (Alembic) ---
# To run migrations manually:
#   pip install a-cal[migrations]
#   alembic upgrade head
# For PostgreSQL: set DATABASE_URL first, then run alembic.
